---
title: Welcome
name: homepage
---

{% extends 'layouts/base.njk' %}

{% block pageTitle %}{{ title }} - {{ super() }}{% endblock %}

{% block bodyId %}{{ name }}{% endblock %}

{% block content %}
  <section id="topline">
    <div class="wrapper">
      <div class="topline-left">
        <h1>Redefining relationships between people, places and property</h1>
      </div>
      <div class="topline-right">
        <p class="toplinep">
          Mortar is a technology company committed to building a better world. We develop intelligent systems, powering the next generation of products and solutions.
        </p>
        <a class="topline-cta" href="#case-studies">Learn about our work</a>
      </div>

      <!-- Recent Content List -->
      <div class="recent-content">
        <div class="recent-content-list">
          {% for item in collections.insights %}
            {% if loop.index <= 2 %}
            <div class="content-item">
              <a href="{{ item.url }}" class="content-link">
                <span class="content-title">{{ item.data.title }}</span>
                <span class="content-category">Insights</span>
              </a>
              {% if item.data.description %}
              <div class="content-description">{{ item.data.description }}</div>
              {% endif %}
            </div>
            {% endif %}
          {% endfor %}

          {% for item in collections.news %}
            {% if loop.index <= 2 %}
            <div class="content-item">
              <a href="{{ item.url }}" class="content-link">
                <span class="content-title">{{ item.data.title }}</span>
                <span class="content-category">News</span>
              </a>
              {% if item.data.description or item.data.excerpt %}
              <div class="content-description">{{ item.data.description or item.data.excerpt }}</div>
              {% endif %}
            </div>
            {% endif %}
          {% endfor %}

          {% for item in collections.caseStudies %}
            {% if loop.index <= 2 %}
            <div class="content-item">
              <a href="{{ item.url }}" class="content-link">
                <span class="content-title">{{ item.data.title }}</span>
                <span class="content-category">Case Studies</span>
              </a>
              {% if item.data.description %}
              <div class="content-description">{{ item.data.description }}</div>
              {% endif %}
            </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </section>

<section id="partners">
  <div class="partners-overlay">
    <a href="/customers" class="partners-cta">Learn about our customers</a>
  </div>
  <div class="partners-wrapper">
    <div class="partners-ticker">
      <ul class="partners-list">
        <li><img src="{{ '/static/images/partners/lga_logo.png' | url }}" alt="Local Government Association logo" /></li>
        <li><img src="{{ '/static/images/partners/GLA-Logo-2.png' | url }}" alt="Greater London Authority logo" /></li>
        <li><img src="{{ '/static/images/partners/havering-council.png' | url }}" alt="Havering Council logo" /></li>
        <li><img src="{{ '/static/images/partners/Hackney-Logo.png' | url }}" alt="Hackney Council logo" /></li>
        <li><img src="{{ '/static/images/partners/Clarion-Housing-Group-Logo.png' | url }}" alt="Clarion Housing Group logo" /></li>
        <li><img src="{{ '/static/images/partners/salford02.png' | url }}" alt="Salford City Council logo" /></li>
        <li><img src="{{ '/static/images/partners/eastriding1.png' | url }}" alt="East Riding of Yorkshire logo" /></li>
        <li><img src="{{ '/static/images/partners/humberandnorth.png' | url }}" alt="Humber and North Yorkshire Integrated Care Partnership logo" /></li>
        <li><img src="{{ '/static/images/partners/walthamforest01.png' | url }}" alt="Waltham Forest logo" /></li>
        <li><img src="{{ '/static/images/partners/Worcestershire-County-Council-logo.png' | url }}" alt="Worcestershire County Council logo" /></li>
        <li><img src="{{ '/static/images/partners/socialfinance01.png' | url }}" alt="Social Finance logo" /></li>
        <li><img src="{{ '/static/images/partners/mayoroflondonlogo01.png' | url }}" alt="Mayor of London logo" /></li>
      </ul>
    </div>
  </div>
</section>

<section id="services">
  <div class="services-heading-wrapper">
    <h2 class="services-heading"><span class="services-heading--pink">Trusted technology builders.</span> <span class="services-heading--blue">Leading research, design and the application of intelligence.</span></h2>
  </div>
  <div class="services-wrapper">

    <nav class="services-nav">
      <button class="service-nav-item is-active" data-service="0">Finding new solutions</button>
      <button class="service-nav-item" data-service="1">Transforming systems</button>
      <button class="service-nav-item" data-service="2">Understanding behaviour</button>
      <button class="service-nav-item" data-service="3">Redefining impact</button>
    </nav>

    <div class="services-content">
      <div class="service-panel is-active" data-service="0">
        <div class="service-panel-text">
          <p>Existing solutions have been heavily influenced by bias, incomplete data and asymmetry in user needs. We use modular, adaptive and intelligent frameworks to build a new generation of solutions; more equitable, adaptive and user-centric.</p>
          <a href="/solutions/" class="service-panel-link">Our design framework</a>
        </div>
        <div class="service-panel-image">
          <img src="{{ '/static/images/use-cases/co-creation-workshops.jpg' | url }}" alt="Service Design" />
        </div>
      </div>
      <div class="service-panel" data-service="1">
        <div class="service-panel-text">
          <p>Our systems were not built for complexity or change. Siloed information and legacy processes make them difficult to navigate and slow to respond. We integrate data to model, test and discover how systems can deliver responsive, resilient and user-centred experiences.</p>
          <a href="/solutions/" class="service-panel-link">Intelligent systems</a>
        </div>
        <div class="service-panel-image">
          <img src="{{ '/static/images/case-studies/progressonline02.png' | url }}" alt="Technology Build" />
        </div>
      </div>
      <div class="service-panel" data-service="2">
        <div class="service-panel-text">
          <p>Our ability to sense, interpret and respond to the world will shape the future. Yet too many decisions remain based on static assumptions about human behaviour. At Mortar we are pioneering behavioural intelligence, creating new ways of seeing and responding to the world that are more aligned with human understanding.</p>
          <a href="/solutions/" class="service-panel-link">Our research</a>
        </div>
        <div class="service-panel-image">
          <img src="{{ '/static/images/case-studies/hackneycircle01.jpg' | url }}" alt="Data and Intelligence" />
        </div>
      </div>
      <div class="service-panel" data-service="3">
        <div class="service-panel-text">
          <p>Impact should not be something evaluated retrospectively. At Mortar we model impact into the solutions we create, with custom frameworks built in for real-time capture, monitoring and reporting. Enabling teams to see impact clearly, guide decisions and improve outcomes throughout the journey.</p>
          <a href="/solutions/" class="service-panel-link">Impact models and frameworks</a>
        </div>
        <div class="service-panel-image">
          <img src="{{ '/static/images/case-studies/digitalhelpfinder.jpg' | url }}" alt="Research and Strategy" />
        </div>
      </div>
    </div>

  </div>
</section>

<section id="vision">
  <div class="vision-intro">
    <h2 class="vision-title">Powered by Mortar</h2>
    <p class="vision-strapline">Organisations are using Mortar to find new ways of working; improving efficiencies and driving growth.</p>
    <div class="vision-tabs">
      <button class="vision-tab is-active" data-tab="people">People</button>
      <button class="vision-tab" data-tab="places">Places</button>
      <button class="vision-tab" data-tab="property">Property</button>
    </div>
  </div>

  <div class="vision-panels">

    <div class="vision-panel is-active" data-tab="people">
      <div class="vision-panel-header">
        <h3>Improving outcomes for people</h3>
        <p>Our people-centred solutions help organisations understand, reach and serve the individuals who need them most.</p>
      </div>
      <div class="vision-panel-body">
        <ul class="vision-modules">
          <li>Needs assessment and profiling</li>
          <li>User journey mapping</li>
          <li>Community navigation</li>
          <li>Personalised service design</li>
          <li>Outcomes and impact tracking</li>
        </ul>
        <div class="vision-graphic">
          <img src="{{ '/static/images/homepage/Claude_Monet01.jpg' | url }}" alt="People solutions illustration" />
        </div>
      </div>
    </div>

    <div class="vision-panel" data-tab="places">
      <div class="vision-panel-header">
        <h3>Understanding and shaping places</h3>
        <p>Our place intelligence tools help organisations map, model and respond to the dynamics of the communities and environments they serve.</p>
      </div>
      <div class="vision-panel-body">
        <ul class="vision-modules">
          <li>Place intelligence and mapping</li>
          <li>Community asset analysis</li>
          <li>Spatial demand modelling</li>
          <li>Local area planning support</li>
          <li>Place-based impact reporting</li>
        </ul>
        <div class="vision-graphic">
          <img src="{{ '/static/images/homepage/Georges_Seurat.jpg' | url }}" alt="Places solutions illustration" />
        </div>
      </div>
    </div>

    <div class="vision-panel" data-tab="property">
      <div class="vision-panel-header">
        <h3>Smarter property decisions</h3>
        <p>Our property intelligence solutions help organisations optimise assets, forecast demand and make evidence-led investment decisions.</p>
      </div>
      <div class="vision-panel-body">
        <ul class="vision-modules">
          <li>Portfolio analysis and optimisation</li>
          <li>Property demand forecasting</li>
          <li>Asset condition modelling</li>
          <li>Investment scenario planning</li>
          <li>Property impact frameworks</li>
        </ul>
        <div class="vision-graphic">
          <img src="{{ '/static/images/homepage/Claude_Monet01.jpg' | url }}" alt="Property solutions illustration" />
        </div>
      </div>
    </div>

  </div>
</section>

<section id="case-studies">
  <div class="case-studies-wrapper">
    <h2>Case studies</h2>
    <div class="case-studies-grid">
      {% for caseStudy in collections.caseStudies %}
      <a href="{{ caseStudy.url }}" class="case-study-link {% if loop.index > 4 %} hidden {% endif %}"> <!-- Hide the extra case studies -->
        <div class="case-study-card">
          <h3>{{ caseStudy.data.title }}</h3>
          <p class="case-study-desc">{{ caseStudy.data.description }}</p>
          <img src="{{ caseStudy.data.image }}" alt="{{ caseStudy.data.title }} image" class="case-study-image" />
        </div>
      </a>
      {% endfor %}
    </div>

   <!-- Load More Case Studies Button -->
    <div class="case-studies-button-container">
      <button id="load-more-casestudies" class="cta">Load More Case Studies</button>
    </div>

    <!-- Preloader for Case Studies -->
    <div id="case-studies-preloader" class="hidden">
      <div class="spinner"></div>
    </div>
  </div>
</section>

<section id="news-updates">
  <div class="wrapper">
    <h2>Latest News & Updates</h2>
    <div class="news-grid">
      {% for post in collections.news %}
      <div class="news-card {% if loop.index > 3 %} hidden {% endif %}">
        <!-- Background Layer -->
        <div class="news-card-background"></div>

        <!-- Content Layer -->
        <div class="news-card-content">
          {% if post.data.image %}
          <div class="news-image-wrapper">
            <img src="{{ post.data.image | url }}" alt="{{ post.data.title }}" class="news-image">
          </div>
          {% endif %}
          <a href="{{ post.url }}" class="news-title-link">
            <h3>{{ post.data.title }}</h3>
          </a>
          <p class="news-excerpt">{{ post.data.excerpt }}</p>
          <a href="{{ post.url }}" class="read-more-link">Read More →</a>
        </div>
      </div>
      {% endfor %}
    </div>

    <!-- Load More News Button -->
    <div class="news-button-container">
      <button id="load-more-news" class="cta">Load More News</button>
    </div>

    <!-- Preloader for News -->
    <div id="news-preloader" class="hidden">
      <div class="spinner"></div>
    </div>
  </div>
</section>

<section id="solutions">
  <div class="solutions-wrapper">
    <h2>Our Solutions</h2>
    <p class="solutions-description">
      We combine our most successful work into scalable solutions, making them personalised and tailored to the needs of your users.
    </p>

    <!-- Solutions Grid -->
    <div class="solutions-grid">
      {% for solution in collections.solutions %}
      <div class="solution-card">
        
        <!-- Solution Content in Columns -->
        <div class="solution-content">
          <img src="{{ solution.data.label_image }}" alt="{{ solution.data.title }} Label" class="solution-label-image">
          <h3>{{ solution.data.title }}</h3> 
          <p class="solution-desc">{{ solution.data.description }}</p> 
          <a href="{{ solution.url }}" class="find-out-more-link">Find Out More</a> 
        </div>
      </div>
      {% endfor %}
    </div>
  </div>
</section>

<section id="partner-company">
    <p class="partner-company-heading">Mortar has been featured, recommended, and accredited by the following organizations:</p>
    <div class="partner-company-wrapper">
        <ul class="partner-company-list">
            <li><img src="{{ '/static/images/partners/g-cloud-14.png' | url }}" alt="G-Cloud 14 Supplier logo" /></li>
            <li><img src="{{ '/static/images/partners/bbc-logo.png' | url }}" alt="BBC logo" /></li>
            <li><img src="{{ '/static/images/partners/rics-logo.png' | url }}" alt="RICS logo" /></li>
            <li><img src="{{ '/static/images/partners/cyber-essentials-logo.png' | url }}" alt="Cyber Essentials logo" /></li>
        </ul>
    </div>
</section>



<section id="insights">
  <div class="wrapper">
    <div class="section-head">
      <h2>Insights</h2>
      <p class="insights-tagline">
        Explore our insights to find out how we are applying new technology to build better services.
      </p>
    </div>

    <ul id="insight-list">
      {% for post in collections.insights %}
      <li class="{% if loop.index > 3 %}hidden{% endif %}">
        <a class="insight-title" href="{{ post.url }}" aria-label="Insight: {{ post.data.title }}">
          <div class="insight-image" style="background-image: url('{{ '/static/images/insights/' + post.data.image | url }}')">
            <div class="hover-overlay"></div>
          </div>
          <div class="insight-details">
            <div class="insight-title">{{ post.data.title }}</div> <!-- Title now in a div -->
            <div class="insight-description">{{ post.data.description }}</div> <!-- Description now in a div -->
          </div>
        </a>
      </li>
      {% endfor %}
    </ul>
      <div class="insights-button-container">
        <button id="load-more-insights" class="cta">Load More Insights</button>
      </div>
    <div id="insights-preloader" class="hidden">
      <div class="spinner"></div>
    </div>
  </div>
</section>



<section id="contact">
  <div class="wrapper contact-wrapper">
    <!-- Left Column: Contact Info -->
    <div class="contact-info">
      <h2>Get in Touch</h2>
      <p>Interested in learning more about one of our products or tools, need technical support, or want to discuss a project? Fill out our form and we will be in touch with you soon.
      <br><br>Or, skip the form and send us an email:<br><br>office@mortar.works</p>
    </div>

    <!-- Right Column: Contact Form in a Card -->
    <div class="contact-form-card">
      <form id="contactForm" action="https://formspree.io/f/mnnqqnev" method="POST">
        <div>
          <label for="name">Name</label>
          <input type="text" id="name" name="name" required>
        </div>
        
        <div>
          <label for="email">Email</label>
          <input type="email" id="email" name="email" required>
        </div>

        <div>
          <label for="reason">What is the reason for getting in touch?</label>
          <select id="reason" name="reason">
            <option value="General Enquiry">General Enquiry</option>
            <option value="Demo">Demo of an existing tool or product</option>
            <option value="Service Design Support">Service Design Support</option>
            <option value="Technical Consultancy">Technical Consultancy</option>
            <option value="Product Development">Product Development</option>
            <option value="Data Solutions">Data and Intelligence Solutions</option>
            <option value="None">None of the above</option>
          </select>
        </div>

        <div>
          <label for="message">Message</label>
          <textarea id="message" name="message" required></textarea>
        </div>

        <button type="submit">Send Message</button>

        <!-- Preloader/Spinner (initially hidden) -->
        <div id="contact-preloader" class="hidden">
          <div class="spinner"></div>
        </div>
      </form>
    </div>
  </div>
</section>


{% endblock %}