---
title: Welcome
name: homepage
---

{% extends 'layouts/base.njk' %}

{% block pageTitle %}{{ title }} - {{ super() }}{% endblock %}

{% block bodyId %}{{ name }}{% endblock %}

{% block content %}
  <section id="topline">
    <div class="wrapper">
      <div class="topline-left">
        <h1>Redefining relationships between <a class="headline-link headline-link--1" href="#vision-people">people</a>, <a class="headline-link headline-link--2" href="#vision-places">places</a> and <a class="headline-link headline-link--3" href="#vision-property">property</a></h1>
      </div>
      <div class="topline-right">
        <p class="toplinep">
          Mortar is a technology company committed to building a better world. We develop intelligent systems, powering the next generation of products and solutions.
        </p>
        <a class="topline-cta" href="#services">Learn about our work</a>
      </div>

      <!-- Recent Content List -->
      <div class="recent-content">
        <div class="recent-content-list">
          {% for item in collections.allContent %}
            {% if loop.index <= 2 %}
            <div class="content-item">
              <a href="{{ item.url }}" class="content-link">
                <span class="content-title">{{ item.data.title }}</span>
                <span class="content-category">Insights</span>
              </a>
              {% if item.data.description %}
              <div class="content-description">{{ item.data.description }}</div>
              {% endif %}
            </div>
            {% endif %}
          {% endfor %}

          {% for item in collections.news %}
            {% if loop.index <= 2 %}
            <div class="content-item">
              <a href="{{ item.url }}" class="content-link">
                <span class="content-title">{{ item.data.title }}</span>
                <span class="content-category">News</span>
              </a>
              {% if item.data.description or item.data.excerpt %}
              <div class="content-description">{{ item.data.description or item.data.excerpt }}</div>
              {% endif %}
            </div>
            {% endif %}
          {% endfor %}

          {% for item in collections.caseStudies %}
            {% if loop.index <= 2 %}
            <div class="content-item">
              <a href="{{ item.url }}" class="content-link">
                <span class="content-title">{{ item.data.title }}</span>
                <span class="content-category">Case Studies</span>
              </a>
              {% if item.data.description %}
              <div class="content-description">{{ item.data.description }}</div>
              {% endif %}
            </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    </div>
  </section>

<section id="partners">
  <div class="partners-overlay">
    <a href="/customers" class="partners-cta">Learn about our customers</a>
  </div>
  <div class="partners-wrapper">
    <div class="partners-ticker">
      <ul class="partners-list">
        <li><img src="{{ '/static/images/partners/lga_logo.png' | url }}" alt="Local Government Association logo" /></li>
        <li><img src="{{ '/static/images/partners/GLA-Logo-2.png' | url }}" alt="Greater London Authority logo" /></li>
        <li><img src="{{ '/static/images/partners/havering-council.png' | url }}" alt="Havering Council logo" /></li>
        <li><img src="{{ '/static/images/partners/Hackney-Logo.png' | url }}" alt="Hackney Council logo" /></li>
        <li><img src="{{ '/static/images/partners/Clarion-Housing-Group-Logo.png' | url }}" alt="Clarion Housing Group logo" /></li>
        <li><img src="{{ '/static/images/partners/salford02.png' | url }}" alt="Salford City Council logo" /></li>
        <li><img src="{{ '/static/images/partners/eastriding1.png' | url }}" alt="East Riding of Yorkshire logo" /></li>
        <li><img src="{{ '/static/images/partners/humberandnorth.png' | url }}" alt="Humber and North Yorkshire Integrated Care Partnership logo" /></li>
        <li><img src="{{ '/static/images/partners/walthamforest01.png' | url }}" alt="Waltham Forest logo" /></li>
        <li><img src="{{ '/static/images/partners/Worcestershire-County-Council-logo.png' | url }}" alt="Worcestershire County Council logo" /></li>
        <li><img src="{{ '/static/images/partners/socialfinance01.png' | url }}" alt="Social Finance logo" /></li>
        <li><img src="{{ '/static/images/partners/mayoroflondonlogo01.png' | url }}" alt="Mayor of London logo" /></li>
      </ul>
    </div>
  </div>
</section>

<section id="services">
  <div class="services-heading-wrapper">
    <h2 class="services-heading"><span class="services-heading--pink">Trusted technology <span id="typewriter-word">builders</span><span class="typewriter-cursor">|</span></span> <span class="services-heading--blue">Leading <span class="services-keyword">research</span>, <span class="services-keyword">design</span> and the application of <span class="services-keyword">intelligence</span>.</span></h2>
  </div>
  <div class="services-wrapper">

    <nav class="services-nav">
      <button class="service-nav-item is-active" data-service="0">Finding new solutions</button>
      <button class="service-nav-item" data-service="1">Transforming systems</button>
      <button class="service-nav-item" data-service="2">Understanding behaviour</button>
      <button class="service-nav-item" data-service="3">Redefining reporting</button>
    </nav>

    <div class="services-content">
      <div class="service-panel is-active" data-service="0">
        <div class="service-panel-text">
          <p>Existing solutions are heavily influenced by bias, incomplete data and assymetry. We use modular, intelligent frameworks to power a new generation of solutions. Easy to integrate. Simple to scale. Dynamic and personalised for enhancing the user experience.</p>
          <a href="/solutions/" class="service-panel-link">Our design framework</a>
        </div>
        <div class="service-panel-image">
          <img src="{{ '/static/images/use-cases/co-creation-workshops.jpg' | url }}" alt="Service Design" />
        </div>
      </div>
      <div class="service-panel" data-service="1">
        <div class="service-panel-text">
          <p>Traditional systems were not built for complexity or change. Siloed information and legacy processes make them difficult to navigate and slow to respond. We integrate data to model and test systems. Learning how to deliver more responsive, resilient and connected experiences.</p>
          <a href="/solutions/" class="service-panel-link">Intelligent systems</a>
        </div>
        <div class="service-panel-image">
          <img src="{{ '/static/images/case-studies/progressonline02.png' | url }}" alt="Technology Build" />
        </div>
      </div>
      <div class="service-panel" data-service="2">
        <div class="service-panel-text">
          <p>Our ability to sense, interpret and respond to the world is changing rapidly. At Mortar we pioneer behavioural intelligence, creating new ways to combine and respond to complex data and information. So decisions are more aligned with human understanding.</p>
          <a href="/solutions/" class="service-panel-link">Our research</a>
        </div>
        <div class="service-panel-image">
          <img src="{{ '/static/images/case-studies/hackneycircle01.jpg' | url }}" alt="Data and Intelligence" />
        </div>
      </div>
      <div class="service-panel" data-service="3">
        <div class="service-panel-text">
          <p>We continually model the impact of our solutions. Building new datasets and frameworks, informing how we capture, monitor and report in real time. Improving outcomes across the entire journey for both organisations and their users.</p>
          <a href="/solutions/" class="service-panel-link">Impact models and frameworks</a>
        </div>
        <div class="service-panel-image">
          <img src="{{ '/static/images/case-studies/digitalhelpfinder.jpg' | url }}" alt="Research and Strategy" />
        </div>
      </div>
    </div>

  </div>
</section>


<section id="powered-by">
  <div class="wrapper">
    <div class="insights-powered-by">
      <h2 class="powered-by-title">Powered by <span class="logo-tombola">
        <span class="tombola-slide is-current">
          <img src="{{ '/static/images/mortar-logo.svg' | url }}" alt="Mortar" class="tombola-logo" />
        </span>
        <span class="tombola-slide">
          <img src="{{ '/static/images/hoopd-alpha.svg' | url }}" alt="Hoop'd" class="tombola-logo tombola-logo--hoopd" />
        </span>
        <span class="tombola-slide">
          <img src="{{ '/static/images/hxly-logo01.svg' | url }}" alt="Hxly" class="tombola-logo tombola-logo--hxly" />
        </span>
      </span></h2>
      <p class="powered-by-strapline">Organisations use Mortar and our suite of products to power and scale their solutions; improving efficiencies and driving growth.</p>
      <div class="powered-by-links">
        <a href="/content/?filter=product" class="pbl-box">View products</a>
        <a href="/content/?filter=solution" class="pbl-text">View solutions</a>
        <a href="/services/" class="pbl-arrow">Build with us <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
      </div>
    </div>
  </div>
</section>

<section id="insights">
  <div class="wrapper">
    <div class="insights-grid-header">
      <h1>Building a better world. <span id="rotating-emoji">🌍</span></h1>
      <p class="toplinep">At Mortar we are building the framework for human centered applications of technology and intelligence.</p>
    </div>
    <ul id="insight-list">
      {% for post in collections.allContent %}
      {% if loop.index <= 3 %}
      <li data-category="{{ post.data.category | lower | replace(' ', '-') if post.data.category else 'all' }}">
        <a class="insight-card" href="{{ post.url }}" aria-label="Insight: {{ post.data.title }}">
          <div class="insight-card-body">
            <span class="insight-category insight-category--{{ post.data.category | lower | replace(' ', '-') if post.data.category else 'insights' }}">{{ post.data.category or 'Insights' }}</span>
            <h3 class="insight-title">{{ post.data.title }}</h3>
            {% if post.data.description %}
            <p class="insight-description">{{ post.data.description }}</p>
            {% endif %}
          </div>
          {% if post.data.keywords %}
          <div class="insight-card-keywords">
            {% for kw in post.data.keywords %}{% if loop.index <= 7 %}<span class="insight-keyword">{{ kw }}</span>{% endif %}{% endfor %}
          </div>
          {% endif %}
          <div class="insight-card-footer">
            <div class="insight-footer-date">
              <span class="insight-date">{{ post.date | date }}</span>
            </div>
            <div class="insight-author-box">
              <span class="insight-author">{{ post.data.author or 'Mortar' }}</span>
            </div>
            <div class="insight-arrow-box">
              <svg class="insight-arrow" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>
        </a>
      </li>
      {% endif %}
      {% endfor %}
    </ul>

    <div class="insights-view-more">
      <a href="/content/" class="insights-view-more-link">View more content</a>
    </div>

    <div id="insights-preloader" class="hidden">
      <div class="spinner"></div>
    </div>

  </div>
</section>


{% endblock %}
