---
title: Welcome
name: homepage
---

{% extends 'layouts/base.njk' %}

{% block pageTitle %}{{ title }} - {{ super() }}{% endblock %}

{% block bodyId %}{{ name }}{% endblock %}

{% block content %}
  <section id="topline">
    <div class="wrapper">
      <div class="topline-heading-group">
        <h1>Redefining relationships between <a class="headline-link headline-link--1" href="#vision-people"><span>people</span></a>, <a class="headline-link headline-link--2" href="#vision-places"><span>places</span></a> and <a class="headline-link headline-link--3" href="#vision-property"><span>property</span></a></h1>
        <div class="topline-body">
          <p class="topline-label">What we do</p>
          <p class="toplinep">Mortar is a technology company building intelligent systems. Powering the next generation of solutions, products and services with intelligence and data enhanced systems.</p>
          <a class="topline-cta" href="#services">Learn about our work</a>
        </div>
      </div>
    </div>
  </section>

  <section id="featured-work">
    <div class="featured-grid">

      <div class="featured-intro">
        <h2>Current work</h2>
        <p>We build technology solutions for corporate, place-based, government and health institutions, applying our data and intelligence platforms to deliver lasting impact.</p>
        <a href="{{ '/content/' | url }}" class="featured-intro-cta">See all our work →</a>
      </div>

      <a href="{{ '/content/' | url }}?filter=case-study" class="featured-tile featured-tile--large">
        <span class="featured-tile-arrow" aria-hidden="true"></span>
        <div class="featured-tile-top">
          <img src="{{ '/static/images/partners/Dawn%20Logo%20B%26W.png' | url }}" alt="Dawn Supercomputer" class="featured-tile-logo">
        </div>
        <div class="featured-tile-footer">
          <span class="featured-tile-tag">Research</span>
          <div class="featured-tile-stats">
            <div class="featured-tile-stat">
              <p class="featured-tile-metric">Dawn</p>
              <p class="featured-tile-metric-label">Supercomputer</p>
            </div>
            <div class="featured-tile-stat">
              <p class="featured-tile-metric">Building behavioural models</p>
              <p class="featured-tile-metric-label">New models for understanding and responding to behaviour</p>
            </div>
          </div>
        </div>
      </a>

      <a href="{{ '/content/' | url }}?filter=case-study" class="featured-tile">
        <span class="featured-tile-arrow" aria-hidden="true"></span>
        <div class="featured-tile-top">
          <img src="{{ '/static/images/partners/mayoroflondonlogo01.png' | url }}" alt="Mayor of London" class="featured-tile-logo">
        </div>
        <div class="featured-tile-footer">
          <span class="featured-tile-tag">Housing</span>
          <p class="featured-tile-metric">Greater London Authority, Mayor of London</p>
          <p class="featured-tile-metric-label">Tenancy sustainment tool</p>
        </div>
      </a>

      <a href="{{ '/content/' | url }}?filter=case-study" class="featured-tile">
        <span class="featured-tile-arrow" aria-hidden="true"></span>
        <div class="featured-tile-top">
          <img src="{{ '/static/images/partners/Department_for_Science_Innovation_and_Technology_logo.png' | url }}" alt="Department for Science, Innovation and Technology" class="featured-tile-logo">
        </div>
        <div class="featured-tile-footer">
          <span class="featured-tile-tag">Government</span>
          <p class="featured-tile-metric">Dept. for Science, Innovation &amp; Technology</p>
          <p class="featured-tile-metric-label">Enhancing the impact of digital skills</p>
        </div>
      </a>

      <a href="{{ '/content/' | url }}?filter=case-study" class="featured-tile">
        <span class="featured-tile-arrow" aria-hidden="true"></span>
        <div class="featured-tile-top">
          <img src="{{ '/static/images/partners/southbankcentre-logo.png' | url }}" alt="Southbank Centre" class="featured-tile-logo">
        </div>
        <div class="featured-tile-footer">
          <span class="featured-tile-tag">Health</span>
          <p class="featured-tile-metric">Southbank Centre and NHS Integrated Care Board</p>
          <p class="featured-tile-metric-label">Children's mental health platform</p>
        </div>
      </a>

      <a href="{{ '/content/' | url }}?filter=case-study" class="featured-tile">
        <span class="featured-tile-arrow" aria-hidden="true"></span>
        <div class="featured-tile-top">
          <img src="{{ '/static/images/partners/humberandnorth.png' | url }}" alt="Humber and North Yorkshire" class="featured-tile-logo">
        </div>
        <div class="featured-tile-footer">
          <span class="featured-tile-tag">Government</span>
          <p class="featured-tile-metric">Humber &amp; North Yorkshire</p>
          <p class="featured-tile-metric-label">Shared directory and triage</p>
        </div>
      </a>

    </div>
  </section>

<section id="partners">
  <div class="partners-overlay">
    <a href="/content/?filter=industry" class="partners-cta">Learn about our customers</a>
  </div>
  <div class="partners-wrapper">
    <div class="partners-ticker">
      <ul class="partners-list">
        <li><img src="{{ '/static/images/partners/lga_logo.png' | url }}" alt="Local Government Association logo" /></li>
        <li><img src="{{ '/static/images/partners/GLA-Logo-2.png' | url }}" alt="Greater London Authority logo" /></li>
        <li><img src="{{ '/static/images/partners/havering-council.png' | url }}" alt="Havering Council logo" /></li>
        <li><img src="{{ '/static/images/partners/Hackney-Logo.png' | url }}" alt="Hackney Council logo" /></li>
        <li><img src="{{ '/static/images/partners/Clarion-Housing-Group-Logo.png' | url }}" alt="Clarion Housing Group logo" /></li>
        <li><img src="{{ '/static/images/partners/salford04.png' | url }}" alt="Salford City Council logo" /></li>
        <li><img src="{{ '/static/images/partners/eastriding1.png' | url }}" alt="East Riding of Yorkshire logo" /></li>
        <li><img src="{{ '/static/images/partners/humberandnorth.png' | url }}" alt="Humber and North Yorkshire Integrated Care Partnership logo" /></li>
        <li><img src="{{ '/static/images/partners/walthamforest01.png' | url }}" alt="Waltham Forest logo" /></li>
        <li><img src="{{ '/static/images/partners/Worcestershire-County-Council-logo.png' | url }}" alt="Worcestershire County Council logo" /></li>
        <li><img src="{{ '/static/images/partners/socialfinance01.png' | url }}" alt="Social Finance logo" /></li>
        <li><img src="{{ '/static/images/partners/mayoroflondonlogo01.png' | url }}" alt="Mayor of London logo" /></li>
      </ul>
    </div>
  </div>
</section>

<section id="services">
  <div class="services-heading-wrapper">
    <h2 class="services-heading"><span class="services-heading--pink">Trusted technology <br><span id="typewriter-word">builders</span><span class="typewriter-cursor">|</span></span> <span class="services-heading--blue">Leading <span class="services-keyword">research</span>, <span class="services-keyword">design</span> and the application of <span class="services-keyword">intelligence</span>.</span></h2>
  </div>
  <div class="services-wrapper">

    <nav class="services-nav">
      <button class="service-nav-item is-active" data-service="0">Design intelligence</button>
      <button class="service-nav-item" data-service="1">Data adaption</button>
      <button class="service-nav-item" data-service="2">Understanding behaviour</button>
      <button class="service-nav-item" data-service="3">Redefining reporting</button>
    </nav>

    <div class="services-content">
      <div class="service-panel is-active" data-service="0">
        <div class="service-panel-text">
          <p>Traditional design methods are built on untested assumptions about users, their needs and behaviour. We simulate systems and services,   modelling users to develop decision surfaces that make systems and services observable, measurable and structured for continuous improvement from the outset.</p>
          <a href="/solutions/service-design/" class="service-panel-link">Our design framework</a>
        </div>
        <div class="service-panel-image">
          <img src="{{ '/static/images/use-cases/co-creation-workshops.jpg' | url }}" alt="Service Design" />
        </div>
      </div>
      <div class="service-panel" data-service="1">
        <div class="service-panel-text">
          <p>Datasets from disparate systems are difficult to analyse. They do not share ontologies or common data models. We build interoperable environments that make data portable, combinable and meaningful in context. Turning fragmented information into the foundation for driving modelling, analysis and insight.</p>
          <a href="/solutions/system-design/" class="service-panel-link">Intelligent systems</a>
        </div>
        <div class="service-panel-image">
          <img src="{{ '/static/images/case-studies/progressonline02.png' | url }}" alt="Technology Build" />
        </div>
      </div>
      <div class="service-panel" data-service="2">
        <div class="service-panel-text">
          <p>Our ability to sense, interpret and respond to the world is changing rapidly. At Mortar we pioneer behavioural intelligence, creating new ways to combine and respond to complex data and information. So decisions are more aligned with human understanding and experience.</p>
          <a href="/products/hxly/" class="service-panel-link">Our research</a>
        </div>
        <div class="service-panel-image">
          <img src="{{ '/static/images/case-studies/hackneycircle01.jpg' | url }}" alt="Data and Intelligence" />
        </div>
      </div>
      <div class="service-panel" data-service="3">
        <div class="service-panel-text">
          <p>We continually model the impact of our solutions. Building new datasets and frameworks, informing how we capture, monitor and report in real time. Improving outcomes across the entire journey for both organisations and their users.</p>
          <a href="/solutions/bigger-impact/" class="service-panel-link">Impact models and frameworks</a>
        </div>
        <div class="service-panel-image">
          <img src="{{ '/static/images/case-studies/digitalhelpfinder.jpg' | url }}" alt="Research and Strategy" />
        </div>
      </div>
    </div>

  </div>
</section>


<section id="powered-by">
  <img src="{{ '/static/images/mortar-bricks.svg' | url }}" alt="" aria-hidden="true" class="powered-by-bricks">
  <div class="wrapper">
    <h2 class="powered-by-title">Powered by Mortar</h2>
    <div class="insights-powered-by">
      <h3 class="powered-by-box-title">Driving the application of new technology.</h3>
      <p class="powered-by-strapline">Organisations use Mortar and our suite of products to power and scale their solutions; improving efficiencies and driving growth.</p>
      <div class="powered-by-links">
        <a href="/content/?filter=product" class="pbl-box">View products</a>
        <a href="/content/?filter=solution" class="pbl-text">View solutions</a>
        <a href="/services/" class="pbl-arrow">Build with us <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true"><path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg></a>
      </div>
    </div>
  </div>
</section>

<section id="insights">

  <div class="wrapper">
    <div class="insights-grid-header">
      <h1>Building a better world. <span id="rotating-emoji">🌍</span></h1>
      <p class="toplinep">At Mortar we are building the framework for human centered applications of technology and intelligence.</p>
    </div>
    <ul id="insight-list">
      {% for post in collections.allContent %}
      {% if loop.index <= 3 %}
      <li data-category="{{ post.data.categories | join(' ') if post.data.categories else (post.data.category | lower | replace(' ', '-') if post.data.category else 'all') }}">
        <a class="insight-card" href="{{ post.url }}" aria-label="Insight: {{ post.data.title }}">
          <div class="insight-card-body">
            <span class="insight-category insight-category--{{ post.data.category | lower | replace(' ', '-') if post.data.category else 'insights' }}">{{ post.data.category or 'Insights' }}</span>
            <h3 class="insight-title">{{ post.data.title }}</h3>
            {% if post.data.description %}
            <p class="insight-description">{{ post.data.description }}</p>
            {% endif %}
          </div>
          {% if post.data.keywords %}
          <div class="insight-card-keywords">
            {% for kw in post.data.keywords %}{% if loop.index <= 7 %}<span class="insight-keyword">{{ kw }}</span>{% endif %}{% endfor %}
          </div>
          {% endif %}
          <div class="insight-card-footer">
            <div class="insight-footer-date">
              <span class="insight-date">{{ post.date | date }}</span>
            </div>
            <div class="insight-author-box">
              <span class="insight-author">{{ post.data.author or 'Mortar' }}</span>
            </div>
            <div class="insight-arrow-box">
              <svg class="insight-arrow" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M9 18l6-6-6-6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>
        </a>
      </li>
      {% endif %}
      {% endfor %}
    </ul>

    <div class="insights-view-more">
      <a href="/content/" class="insights-view-more-link">View more content</a>
    </div>

    <div id="insights-preloader" class="hidden">
      <div class="spinner"></div>
    </div>

  </div>
</section>


{% endblock %}
