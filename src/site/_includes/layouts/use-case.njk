{% extends 'layouts/base.njk' %}

{% block pageTitle %}{{ title }} - Use cases - {{ super() }}{% endblock %}
{% block bodyId %}{{ title | slug }}{% endblock %}
{% block mainClass %}use-case content-page{% endblock %}

{% set previousPost = collections.useCases | getPreviousCollectionItem(page) %}
{% set nextPost = collections.useCases | getNextCollectionItem(page) %}

{% block content %}
<section>
  <div class="wrapper article-layout">
    <nav class="article-toc" id="article-toc" aria-label="Article contents"></nav>

    <div class="article-main">
      <div class="article-header">
        <h1>{{ title }}</h1>
        {% if description %}
          <p class="article-strapline">{{ description }}</p>
        {% endif %}
        <p class="article-date">{{ date | date }}</p>
      </div>

      <article class="article-content">
        {{ content | safe }}
      </article>

      {% if keywords %}
      <div class="article-keywords">
        {% for keyword in keywords %}
          <span class="article-keyword">{{ keyword }}</span>
        {% endfor %}
      </div>
      {% endif %}

      <p class="solution-get-in-touch">
        <a class="cta" href="https://draft.mortar.works/#contact" target="_blank" rel="noopener">Get in touch</a>
      </p>

      <div class="other-content">
        {% if previousPost %}
          <div class="previous-post">
            <a href="{{ previousPost.url }}">
              <span>Previous use case</span>
              <span class="post-title">{{ previousPost.data.title }}</span>
            </a>
          </div>
        {% endif %}
        {% if nextPost %}
          <div class="next-post">
            <a href="{{ nextPost.url }}">
              <span>Next use case</span>
              <span class="post-title">{{ nextPost.data.title }}</span>
            </a>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>
{% endblock %}
