{% extends 'layouts/base.njk' %}

{% set section = 'insights' %}
{% block pageTitle %}{{ title }} - Insights - {{ super() }}{% endblock %}
{% block mainClass %}insight-page content-page{% endblock %}

{% set previousPost = collections.insights | getPreviousCollectionItem(page) %}
{% set nextPost = collections.insights | getNextCollectionItem(page) %}

{% block content %}
<section>
  <div class="wrapper article-layout">
    <div class="article-main">
      <div class="article-header">
        <div class="article-header-text">
          {% if logo %}
            <img class="article-header-logo" src="{{ logo }}" alt="{{ title }} logo">
          {% else %}
            <h1>{{ title }}</h1>
          {% endif %}
          {% if description %}
            <p class="article-strapline">{{ description }}</p>
          {% endif %}
          <p class="article-date">Last updated on {{ date | date }}</p>
          <nav class="article-toc" id="article-toc" aria-label="Article contents"></nav>
        </div>
      </div>

      <article class="article-content">
        {{ content | safe }}
      </article>

      {% if keywords %}
      <div class="article-keywords">
        {% for keyword in keywords %}
          <a class="article-keyword" href="/content/?search={{ keyword | replace(' ', '+') }}">{{ keyword }}</a>
        {% endfor %}
      </div>
      {% endif %}

      <p class="solution-get-in-touch">
        <a class="cta" href="/contact/">Get in touch</a>
      </p>

      <div class="other-content">
        {% if previousPost %}
          <div class="previous-post">
            <a href="{{ previousPost.url }}">
              <span>Previous insight</span>
              <span class="post-title">{{ previousPost.data.title }}</span>
            </a>
          </div>
        {% endif %}
        {% if nextPost %}
          <div class="next-post">
            <a href="{{ nextPost.url }}">
              <span>Next insight</span>
              <span class="post-title">{{ nextPost.data.title }}</span>
            </a>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>
{% endblock %}
