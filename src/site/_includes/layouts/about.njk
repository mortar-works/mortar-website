{% extends 'layouts/base.njk' %}

{% block pageTitle %}{{ title }} - {{ super() }}{% endblock %}
{% block bodyId %}about-mortar{% endblock %}
{% block mainClass %}content-page{% endblock %}

{% block content %}
<section id="about-hero">
  <div class="wrapper">
    <div class="about-hero-left">
      <h1>Building a better world through technology</h1>
      <p class="about-strapline">We are committed to building intelligent systems. To power the next generation of products and applications. To align a more equitable society with real human needs and understanding.</p>
      <a href="/contact/" class="about-cta">Work with us</a>
    </div>
    <div class="about-hero-right">
      <p class="about-articles-label">Latest thinking</p>
      <div class="about-articles-list">
        {% for item in collections.insights %}
          {% if item.data.category == 'company' %}
          <div class="about-article-item">
            <a href="{{ item.url }}" class="about-article-link">
              <span class="about-article-title">{{ item.data.title }}</span>
              <span class="about-article-category">Company</span>
            </a>
          </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>
  </div>
</section>

<section id="about-values">
  <div class="wrapper">
    <p class="values-label">What drives us</p>
    <div class="values-grid">
      <div class="value-card">
        <h3>Human first</h3>
        <p>Every decision begins by understanding the people using and impacted by the systems we build.</p>
      </div>
      <div class="value-card">
        <h3>Data led</h3>
        <p>We operate on knowledge, not assumptions. When we don't know, we say so; and then we find out.</p>
      </div>
      <div class="value-card">
        <h3>Long-term thinking</h3>
        <p>We build for sustainability. Our systems are designed to grow and adapt, responding to changes in use and need.</p>
      </div>
      <div class="value-card">
        <h3>Equity by design</h3>
        <p>Accessibility and inclusion are not afterthoughts. They are embedded in how we research, design, and build.</p>
      </div>
    </div>
  </div>
</section>

<section id="about-content">
  <div class="wrapper article-layout">
    <nav class="article-toc" id="article-toc" aria-label="Page contents"></nav>
    <div class="article-main">
      <article class="article-content">
        {{ content | safe }}
      </article>
      <p class="solution-get-in-touch">
        <a class="cta" href="/contact/">Get in touch</a>
      </p>
    </div>
  </div>
</section>
{% endblock %}
