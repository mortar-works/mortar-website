{% extends 'layouts/base.njk' %}

{% block pageTitle %}{{ title }} - {{ super() }}{% endblock %}
{% block bodyId %}{{ title | slug }}{% endblock %}
{% block mainClass %}content-page{% endblock %}

{% block content %}
<section>
  <div class="wrapper">
    <article>
      <h1>{{ title }}</h1>
      {{ content | safe }}
    </article>
  </div>
</section>
{% endblock %}
