<!doctype html>
<html lang="en">
  <head>
    <title>
      {% block pageTitle %}Building better services{% endblock %}
    </title>
    <meta charset="utf-8">
    <meta http-equiv="Content-Type" content="text/html; charset=utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Mortar powers intelligent, accessible, and human-centric solutions for society. We are a technology company committed to building a better world.">

    <link rel="shortcut icon" href="{{ '/static/images/mortar-favicon.png' | url }}" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&display=swap">
    <link rel="stylesheet" href="{{ '/static/css/styles.css' | url }}">
    <script async="async" defer="defer" src="{{ '/static/js/main.js' | url }}"></script>

    {% if bodyId == "solutions" %}
  <link rel="stylesheet" href="/static/css/solutions.css">

   {% elseif bodyId == "news" %}
      <link rel="stylesheet" href="/static/css/news.css">
      
  {% endif %}
  </head>
  <body id="{% block bodyId %}{% endblock %}">
    <header>
      <div class="wrapper">
        <div class="header-left">
          <a href="/" id="mortar-logo">
            <img src="/static/images/mortar-logo-white.png" alt="Mortar" height="47" width="105">
          </a>

          <nav aria-label="Main navigation">
            <ul>
              <li class="nav-has-dropdown">
                <button class="nav-dropdown-toggle" aria-expanded="false" aria-haspopup="true">
                  Products <span class="dropdown-chevron" aria-hidden="true"></span>
                </button>
                <div class="nav-dropdown-menu nav-dropdown-menu--products" role="menu">
                  <div class="dropdown-section">
                    <span class="dropdown-subheading">Mainline</span>
                    <a href="#" role="menuitem" class="product-link">
                      <span class="product-name">Harla <span class="link-chevron" aria-hidden="true"></span></span>
                      <span class="product-desc">Our intelligent management system for custom property solutions.</span>
                    </a>
                    <a href="#" role="menuitem" class="product-link">
                      <span class="product-name">Hoop'd <span class="link-chevron" aria-hidden="true"></span></span>
                      <span class="product-desc">Our intelligent design system for connecting people and places.</span>
                    </a>
                    <a href="#" role="menuitem" class="product-link">
                      <span class="product-name">Hxly <span class="link-chevron" aria-hidden="true"></span></span>
                      <span class="product-desc">Our platform for the development of behavioural intelligence.</span>
                    </a>
                    <a href="#" role="menuitem" class="dropdown-link--more">Product development <span class="link-chevron" aria-hidden="true"></span></a>
                  </div>
                </div>
              </li>
              <li class="nav-has-dropdown">
                <button class="nav-dropdown-toggle" aria-expanded="false" aria-haspopup="true">
                  Solutions <span class="dropdown-chevron" aria-hidden="true"></span>
                </button>
                <div class="nav-dropdown-menu nav-dropdown-menu--wide" role="menu">
                  <div class="dropdown-columns">
                    <div class="dropdown-column">
                      <span class="dropdown-subheading">Services</span>
                      <a href="{{ '/solutions/service-design/' | url }}" role="menuitem">Service design <span class="link-chevron" aria-hidden="true"></span></a>
                      <a href="{{ '/solutions/system-design/' | url }}" role="menuitem">System design <span class="link-chevron" aria-hidden="true"></span></a>
                      <a href="{{ '/solutions/modelling-and-simulation/' | url }}" role="menuitem">Modelling and simulation <span class="link-chevron" aria-hidden="true"></span></a>
                      <a href="#" role="menuitem">People <span class="link-chevron" aria-hidden="true"></span></a>
                      <a href="#" role="menuitem">Places <span class="link-chevron" aria-hidden="true"></span></a>
                      <a href="#" role="menuitem">Property <span class="link-chevron" aria-hidden="true"></span></a>
                      <a href="#" role="menuitem" class="dropdown-link--more">Service overview <span class="link-chevron" aria-hidden="true"></span></a>
                    </div>
                    <div class="dropdown-column">
                      <span class="dropdown-subheading">Use Cases</span>
                      <a href="#" role="menuitem">Smarter decisions <span class="link-chevron" aria-hidden="true"></span></a>
                      <a href="#" role="menuitem">Stronger teams <span class="link-chevron" aria-hidden="true"></span></a>
                      <a href="#" role="menuitem">Bigger impact <span class="link-chevron" aria-hidden="true"></span></a>
                      <a href="#" role="menuitem">Shared value <span class="link-chevron" aria-hidden="true"></span></a>
                      <a href="#" role="menuitem">Better connections <span class="link-chevron" aria-hidden="true"></span></a>
                      <a href="#" role="menuitem" class="dropdown-link--more">View all use cases <span class="link-chevron" aria-hidden="true"></span></a>
                    </div>
                    <div class="dropdown-column">
                      <span class="dropdown-subheading">Industries</span>
                      <a href="#" role="menuitem">Health <span class="link-chevron" aria-hidden="true"></span></a>
                      <a href="#" role="menuitem">Government <span class="link-chevron" aria-hidden="true"></span></a>
                      <a href="#" role="menuitem">Cultural Sector <span class="link-chevron" aria-hidden="true"></span></a>
                      <a href="#" role="menuitem">Housing <span class="link-chevron" aria-hidden="true"></span></a>
                      <a href="#" role="menuitem">Asset management <span class="link-chevron" aria-hidden="true"></span></a>
                      <a href="#" role="menuitem" class="dropdown-link--more">Our industries <span class="link-chevron" aria-hidden="true"></span></a>
                    </div>
                  </div>
                </div>
              </li>
              <li class="nav-has-dropdown">
                <button class="nav-dropdown-toggle" aria-expanded="false" aria-haspopup="true">
                  Customers <span class="dropdown-chevron" aria-hidden="true"></span>
                </button>
                <div class="nav-dropdown-menu" role="menu">
                  <div class="dropdown-section">
                    <span class="dropdown-subheading">Case studies</span>
                    <a href="#" role="menuitem">Transport for London <span class="link-chevron" aria-hidden="true"></span></a>
                    <a href="#" role="menuitem">Southbank Centre <span class="link-chevron" aria-hidden="true"></span></a>
                    <a href="#" role="menuitem">Gloucestershire <span class="link-chevron" aria-hidden="true"></span></a>
                    <a href="#" role="menuitem" class="dropdown-link--more">View all <span class="link-chevron" aria-hidden="true"></span></a>
                  </div>
                </div>
              </li>
              <li class="nav-has-dropdown">
                <button class="nav-dropdown-toggle" aria-expanded="false" aria-haspopup="true">
                  Content <span class="dropdown-chevron" aria-hidden="true"></span>
                </button>
                <div class="nav-dropdown-menu nav-dropdown-menu--wide" role="menu">
                  <div class="dropdown-columns">
                    <div class="dropdown-column">
                      <span class="dropdown-subheading">Latest content</span>
                      <a href="{{ '/insights/driving-product-development/' | url }}" role="menuitem">Driving product development <span class="link-chevron" aria-hidden="true"></span></a>
                      <a href="{{ '/insights/intelligent-user-pathways/' | url }}" role="menuitem">Intelligent User Pathways <span class="link-chevron" aria-hidden="true"></span></a>
                      <a href="{{ '/insights/dynamic-information-directories/' | url }}" role="menuitem">Dynamic Information Directories <span class="link-chevron" aria-hidden="true"></span></a>
                      <a href="{{ '/insights/custom-engagement-environments/' | url }}" role="menuitem">Custom engagement environments <span class="link-chevron" aria-hidden="true"></span></a>
                      <a href="{{ '/#insights' | url }}" role="menuitem" class="dropdown-link--more">View all <span class="link-chevron" aria-hidden="true"></span></a>
                    </div>
                    <div class="dropdown-column">
                      <span class="dropdown-subheading">Categories</span>
                      <a href="#" role="menuitem">Product <span class="link-chevron" aria-hidden="true"></span></a>
                      <a href="#" role="menuitem">Solution <span class="link-chevron" aria-hidden="true"></span></a>
                      <a href="#" role="menuitem">Research <span class="link-chevron" aria-hidden="true"></span></a>
                      <a href="#" role="menuitem">Use Case <span class="link-chevron" aria-hidden="true"></span></a>
                      <a href="#" role="menuitem">Case Study <span class="link-chevron" aria-hidden="true"></span></a>
                      <a href="#" role="menuitem">Service <span class="link-chevron" aria-hidden="true"></span></a>
                      <a href="#" role="menuitem">Customer <span class="link-chevron" aria-hidden="true"></span></a>
                      <a href="#" role="menuitem">Industry <span class="link-chevron" aria-hidden="true"></span></a>
                      <a href="#" role="menuitem">Company <span class="link-chevron" aria-hidden="true"></span></a>
                    </div>
                  </div>
                </div>
              </li>
              <li class="nav-has-dropdown">
                <button class="nav-dropdown-toggle" aria-expanded="false" aria-haspopup="true">
                  Company <span class="dropdown-chevron" aria-hidden="true"></span>
                </button>
                <div class="nav-dropdown-menu" role="menu">
                  <div class="dropdown-section">
                    <span class="dropdown-subheading">Who we are</span>
                    <a href="{{ '/about/' | url }}" role="menuitem">About <span class="link-chevron" aria-hidden="true"></span></a>
                    <a href="{{ '/contact/' | url }}" role="menuitem">Contact <span class="link-chevron" aria-hidden="true"></span></a>
                  </div>
                </div>
              </li>
            </ul>
          </nav>
        </div>

        <div class="header-right">
          <a href="{{ '/contact/' | url }}" class="nav-cta nav-cta--outline">Contact</a>
          <div class="nav-has-dropdown header-cta-dropdown">
            <button class="nav-cta nav-cta--solid nav-dropdown-toggle" type="button" aria-expanded="false" aria-haspopup="true">
              View our products <span class="dropdown-chevron" aria-hidden="true"></span>
            </button>
            <div class="nav-dropdown-menu nav-dropdown-menu--visit" role="menu">
              <div class="dropdown-section">
                <a href="#" role="menuitem" class="product-visit-link" target="_blank" rel="noopener">
                  <span class="product-visit-logo product-visit-logo--hoopd"></span>
                  <span class="product-visit-name">Visit Hoop'd</span>
                  <span class="link-chevron" aria-hidden="true"></span>
                </a>
                <a href="#" role="menuitem" class="product-visit-link" target="_blank" rel="noopener">
                  <span class="product-visit-logo product-visit-logo--hxly"></span>
                  <span class="product-visit-name">Visit Hxly</span>
                  <span class="link-chevron" aria-hidden="true"></span>
                </a>
                <a href="#" role="menuitem" class="product-visit-link">
                  <span class="product-visit-logo product-visit-logo--harla"></span>
                  <span class="product-visit-name">Visit Harla</span>
                  <span class="link-chevron" aria-hidden="true"></span>
                </a>
              </div>
            </div>
          </div>
          <button class="hamburger hamburger--squeeze" type="button">
            <span class="visually-hidden">Toggle menu</span>
            <span class="hamburger-box">
              <span class="hamburger-inner"></span>
            </span>
          </button>
        </div>
      </div>
    </header>

    <main class="{% block mainClass %}{% endblock %}">
      {% block content %}{% endblock %}
    </main>

    <footer>
      <div class="wrapper">
        <div id="footer-link-bar">
          <nav aria-label="Footer navigation">
            <ul>
            <li><a href="{{ '/#case-studies' | url }}">Case Studies</a></li>
            <li><a href="{{ '/#solutions' | url }}">Solutions</a></li>
            <li><a href="{{ '/#news-updates' | url }}">News</a></li>
            <li><a href="{{ '/#insights' | url }}">Insights</a></li>
            <li><a href="{{ '/#contact' | url }}">Contact</a></li>
            </ul>
          </nav>

          <div>
            <h3>Solutions</h3>
            <ul>
            {% for solution in collections.solutions %}
              <li>
                <a href="{{ solution.url }}">{{ solution.data.title }}</a>
              </li>
            {% endfor %}
            </ul>
          </div>

          <div>
            <h3>Features</h3>
            <ul>
            {% for feature in features %}
              <li>
                {{ feature.title }}
              </li>
            {% endfor %}
            </ul>
          </div>

        </div>

        <div class="footer-disclaimer">
          <p>
            &copy; 2025 Mortar
          </p>
          <p>
            Mortar Works Limited is a company registered in England and Wales (Co. No. 12169493).
          </p>
        </div>
      </div>
    </footer>

    {% if metadata.environment === 'production' %}
      <script async src="https://www.googletagmanager.com/gtag/js?id=UA-170658582-1"></script>
      <script>
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'UA-170658582-1');
      </script>
    {% endif %}
  </body>
</html>
